        "# Creamos la clase Producto para guardar la informacion de cada producto\n",
        "class Producto:\n",
        "    def __init__(self, nombre, precio, stock, popularidad):\n",
        "      # Aqui guardamos los datos del producto\n",
        "        self.nombre = nombre   # nombre del producto\n",
        "        self.precio = precio   # cuanto cuesta\n",
        "        self.stock = stock     # cuantos hay disponibles\n",
        "        self.popularidad = popularidad  # que tan popular es\n",
        "\n",
        "#Sirve para mostrar la informacion del producto de forma ordenada\n",
        "    def __repr__(self):\n",
        "        return f\"{self.nombre} - ${self.precio} - stock: {self.stock} - prioridad {self.popularidad}\"\n",
        "\n",
        "\n",
        "# Lista de productos\n",
        "productos = [\n",
        "    Producto(\"Laptop\", 800000, 20, 10),\n",
        "    Producto(\"Mouse\", 10000, 20, 3),\n",
        "    Producto(\"Teclado\", 20000, 30, 4),\n",
        "    Producto(\"Monitor\", 150000, 50, 5)\n",
        "]\n",
        "\n",
        "# Ordenar por popularidad (descendente) y luego por stock (descendente)\n",
        "ordenados = sorted(productos, key=lambda p: (-p.popularidad, -p.stock))\n",
        "\n",
        "# Mostrar productos ya ordenados\n",
        "for p in ordenados:\n",
        "    print(p)"
